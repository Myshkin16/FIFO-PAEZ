# Copy to .env.local for local dev (or use `vercel env pull .env.local`
# after `vercel link` and configure these on the Vercel project dashboard).

# ─── Database (Neon Postgres via Vercel Marketplace) ─────────────────────────
# Auto-injected by Vercel when you connect a Neon integration. For local dev,
# `vercel env pull` will fill this in.
DATABASE_URL=postgres://user:pass@host.neon.tech/db?sslmode=require

# ─── At-rest encryption for Kraken keys ──────────────────────────────────────
# 32+ characters of random hex. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: changing this invalidates every existing encrypted Kraken key.
ENCRYPTION_SECRET=

# ─── Clerk auth ──────────────────────────────────────────────────────────────
# From Clerk dashboard → Configure → API Keys. The "publishable" key is safe
# to ship to the browser; the "secret" key never leaves the server.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Optional: where Clerk sends users after sign-in / sign-up. Defaults are fine.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
